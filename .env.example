# Admin user seeded on first run (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# HTTP listen port (default: 7685)
# PORT=7685

# Directory for SQLite DB and CLI config (default: data)
# PINGD_DATA_DIR=data

# Logging format: text (default) or json
# PINGD_LOG_FORMAT=text

# Log level: trace, debug, info, notice (default), warning, error, critical
# Set to "info" to see request logs
# LOG_LEVEL=notice

# Allow public user registration (default: false)
# PINGD_ALLOW_REGISTRATION=true

# Enable guest login (default: true). When false, POST /auth/guest returns 403
# PINGD_GUEST_ENABLED=false

# CORS: "*" or comma-separated allowed origins (default: *)
# PINGD_CORS_ORIGIN=https://pingd.dev,https://admin.pingd.dev

# General per-IP rate limit count. Default: 30
# PINGD_RATE_LIMIT_COUNT=30

# Per-user publish limit per 60s for authenticated callers. Unset = unlimited
# PINGD_PUBLISH_RATE_LIMIT_PER_USER_PER_MIN=60

# Per-IP publish limit per 60s for anonymous callers. Unset = unlimited
# PINGD_ANON_PUBLISH_RATE_LIMIT_PER_IP_PER_MIN=20

# Webhook receive rate limits (production only)
# PINGD_WEBHOOK_RATE_LIMIT_PER_TOKEN=120
# PINGD_WEBHOOK_RATE_LIMIT_PER_IP=300

# Comma-separated reserved topic names (case-insensitive)
# PINGD_RESERVED_TOPIC_NAMES=admin,system,internal

# Default publicRead/publicPublish when topic create body omits the field. (default: publicRead=false, publicPublish=false)
# PINGD_DEFAULT_PUBLIC_READ=false
# PINGD_DEFAULT_PUBLIC_PUBLISH=false

# Default share token expiry when caller omits expiresAt. Format: 30d, 12h, 5m, 60s
# PINGD_DEFAULT_SHARE_TOKEN_TTL=30d

# Default permission expiry when admin omits expiresAt. Same format as above
# PINGD_DEFAULT_PERMISSION_TTL=90d

# Max topics per non-admin user. (default: unlimited)
# PINGD_MAX_TOPICS_PER_USER=50

# Max active share tokens per topic. (default: unlimited)
# PINGD_MAX_SHARE_TOKENS_PER_TOPIC=10

# APNS push mode: direct or relay (omit to disable push)
# PINGD_APNS_MODE=direct

# Direct mode: server sends to Apple directly (requires Apple Developer credentials)
# PINGD_APNS_KEY_PATH=/run/secrets/apns.p8
# PINGD_APNS_KEY_ID=ABC123DEFG
# PINGD_APNS_TEAM_ID=TEAMID1234
# PINGD_APNS_BUNDLE_ID=com.example.pingd
# PINGD_APNS_ENV=production

# Relay mode: server forwards push jobs to a direct-mode server.
# PINGD_APNS_MODE=relay
# PINGD_APNS_RELAY_BASE_URL=https://pingd.dev
# PINGD_APNS_RELAY_TOKEN=your-user-token

# Web Push for browser notifications
# PINGD_WEBPUSH_VAPID_CONFIG={"contactInformation":"mailto:admin@example.com","expirationDuration":79200,"primaryKey":"base64-vapid-private-key","validityDuration":72000}
