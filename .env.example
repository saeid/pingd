# Admin user seeded on first run (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Logging format: text (default) or json
# PINGD_LOG_FORMAT=text

# Log level: trace, debug, info, notice (default in production), warning, error, critical
# Set to "info" to see request logs in production
# LOG_LEVEL=notice

# Allow public user registration (default: false)
# PINGD_ALLOW_REGISTRATION=true

# APNS push mode: direct or relay (omit to disable push)
# PINGD_APNS_MODE=direct

# Direct mode: server sends to Apple directly (requires Apple Developer credentials)
# PINGD_APNS_KEY_PATH=/run/secrets/apns.p8
# PINGD_APNS_KEY_ID=ABC123DEFG
# PINGD_APNS_TEAM_ID=TEAMID1234
# PINGD_APNS_BUNDLE_ID=com.example.pingd
# PINGD_APNS_ENV=production

# Relay mode: server forwards push jobs to a direct-mode server (e.g. pingd.io)
# PINGD_APNS_MODE=relay
# PINGD_APNS_RELAY_BASE_URL=https://pingd.io
# PINGD_APNS_RELAY_TOKEN=your-hosted-user-token
